# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your own values.
# NEVER commit your real `.env` file to version control.
# ---------------------------------------------------------------------------

# --- AWS Bedrock credentials ---
# Create an IAM user with bedrock:InvokeModel permission and paste the keys here.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# Bedrock model id (any chat-capable model your account has access to)
BEDROCK_MODEL_ID=us.meta.llama3-3-70b-instruct-v1:0
LLM_TEMPERATURE=0.1

# --- Company / branding ---
# These values shape how the assistant phrases answers ("we", company name, etc.)
COMPANY_NAME=Acme Analytics, Inc.
COMPANY_SHORT_NAME=Acme Analytics
COMPANY_DOMAIN=acme.example
COMPANY_FOUNDING_YEAR=2010
# Optional: comma-separated alias=canonical pairs the model treats as the company
# COMPANY_ALIASES=acme=Acme Analytics,acme.example=Acme Analytics, Inc.

# --- Data / paths ---
KNOWLEDGE_BASE_PATH=data/sample_ddq_knowledge_base.csv
EXPORTS_DIR=ddq_exports
POLICIES_DIR=policies

# --- Retrieval ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
RETRIEVER_TOP_K=4

# --- Server ---
SERVER_NAME=127.0.0.1
SERVER_PORT=7860
